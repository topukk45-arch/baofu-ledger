<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 全局窗口背景：与网页主题默认底色一致的浅青。
         键盘弹起/切换不同高度输入法时，WebView 与键盘之间可能露出窗口背景，
         把它钉成浅青可避免露出刺眼的白条（"白图"），也与默认主题（雾松青）一致。 -->
    <color name="appWindowBackground">#F1F9F8</color>

    <!-- 主题主色（styles.xml 引用，补齐定义以确保任何环境都能编译） -->
    <color name="colorPrimary">#3F6F6B</color>
    <color name="colorPrimaryDark">#2C5955</color>
    <color name="colorAccent">#3BA69D</color>
</resources>
